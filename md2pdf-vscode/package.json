{
  "name": "md2pdf-onepage-vscode",
  "displayName": "Markdown → 連続1ページPDF",
  "description": "Markdown を末尾余白のない連続1ページPDFに変換します（Puppeteer製・画像対応）。",
  "version": "1.0.0",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "md2pdfOnepage.convert",
        "title": "PDFに変換(1ページ)",
        "category": "md2pdf"
      },
      {
        "command": "md2pdfOnepage.convertPaged",
        "title": "PDFに変換(改ページあり)",
        "category": "md2pdf"
      }
    ],
    "submenus": [
      {
        "id": "md2pdf.submenu",
        "label": "md2pdf"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .md",
          "submenu": "md2pdf.submenu",
          "group": "navigation@99"
        }
      ],
      "editor/context": [
        {
          "when": "resourceExtname == .md",
          "submenu": "md2pdf.submenu",
          "group": "navigation@99"
        }
      ],
      "editor/title/context": [
        {
          "when": "resourceExtname == .md",
          "submenu": "md2pdf.submenu"
        }
      ],
      "md2pdf.submenu": [
        {
          "command": "md2pdfOnepage.convertPaged",
          "group": "navigation@1"
        },
        {
          "command": "md2pdfOnepage.convert",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "md2pdf-onepage",
      "properties": {
        "md2pdfOnepage.width": {
          "type": "number",
          "default": 210,
          "description": "ページ幅（mm）"
        },
        "md2pdfOnepage.margin": {
          "type": "number",
          "default": 15,
          "description": "余白（mm）"
        },
        "md2pdfOnepage.cssPath": {
          "type": "string",
          "default": "",
          "description": "適用するCSSの絶対パス（空なら同梱 default.css）"
        },
        "md2pdfOnepage.openAfter": {
          "type": "boolean",
          "default": true,
          "description": "生成後にPDFを開く"
        }
      }
    }
  },
  "scripts": {
    "test:core": "node test-core.js"
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "puppeteer": "^25.2.1"
  }
}
